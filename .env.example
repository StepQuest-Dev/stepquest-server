# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://stepquest:stepquest_dev_password@localhost:5432/stepquest?schema=public"

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d

# Throttle (rate limiting)
THROTTLE_TTL=60
THROTTLE_LIMIT=100