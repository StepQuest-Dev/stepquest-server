generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  username     String      @unique
  passwordHash String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  character    Character?
  steps        StepRecord[]
}

model Character {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  name      String
  level     Int      @default(1)
  exp       Int      @default(0)
  gold      Int      @default(0)
  
  hp          Int      @default(100)
  maxHp       Int      @default(100)
  attack      Int      @default(10)
  defense     Int      @default(5)

  totalSteps Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  battles     Battle[]
  combatSessions CombatSession[]
}

model StepRecord {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  count      Int
  recordedAt DateTime @default(now())
  source     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Enemy {
  id          String   @id @default(uuid())
  name        String
  level       Int
  hp          Int
  attack      Int
  defense     Int
  goldReward  Int
  expReward   Int
  imageUrl    String?  // Link do assetu w aplikacji RN
  battles     Battle[]
  combatSessions  CombatSession[]
}

model Battle {
  id          String   @id @default(uuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
  enemyId     String
  enemy       Enemy     @relation(fields: [enemyId], references: [id])
  
  status      BattleStatus @default(PENDING) // PENDING, WON, LOST
  log         Json?        // Przebieg walki (np. tablica uderzeń)
  
  createdAt   DateTime @default(now())

  sessionId   String?
  session     CombatSession? @relation(fields: [sessionId], references: [id])
}

enum BattleStatus {
  PENDING
  WON
  LOST
}

model CombatSession {
  id          String        @id @default(uuid())
  characterId String
  character   Character     @relation(fields: [characterId], references: [id])
  enemyId     String
  enemy       Enemy         @relation(fields: [enemyId], references: [id])
  status      BattleStatus  @default(PENDING)
  createdAt   DateTime      @default(now())

  battles     Battle[]
}

enum CombatAction {
  ATTACK
  FLEE
  USE_ITEM
}
